  </div>

  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} Joanny Bernardeau</p>
  </div>
</footer>
<style>
.footer {
  margin-top: 4rem;
  padding: 1rem;
  background: linear-gradient(var(--gray-gradient));
  color: rgb(var(--gray));
}

.footer-content {
  max-width: 900px;
  margin: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
}

.footer-brand {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
}

.footer-brand .name {
  font-weight: bold;
  font-size: 1.2rem;
}

.footer-brand .tagline {
  font-size: 0.9rem;
  opacity: 0.7;
}

.footer-links {
  display: flex;
  gap: 1.2rem;
}

.footer-links a {
  color: rgb(var(--gray));
  transition: all 0.2s ease;
}

.footer-links a:hover {
  color: white;
  transform: translateY(-2px);
}

.footer-bottom {
  text-align: center;
  font-size: 0.8rem;
  opacity: 0.6;
}
</style>
